<launch>
<node pkg="gmapping" type="slam_gmapping" name="slam_gmapping">
        <rosparam>
        use_sim_time: true
        odom_frame: world
        base_frame: true_body
        map_frame: map

        map_update_interval: 0.5 # Publish new map

        maxUrange: 8.9 # Should be just less than sensor range
        maxRange: 9.5 # Should be just greater than sensor range
        particles:  100 # 

        # Update frequencies
        linearUpdate: 1.0
        angularUpdate: 1.0
        temporalUpdate: 1.0
        resampleThreshold: 0.5
        iterations: 1

        # Initial Map Size
        xmin: -10.0
        ymin: -10.0
        xmax: 10.0
        ymax: 10.0
        delta: 0.05

        # All default
        sigma: 0.05
        kernelSize: 5
        lstep: 0.05
        astep: 0.05
        iterations: 5
        lsigma: 0.075
        ogain: 3.0
        lskip: 0
        llsamplerange: 0.01
        llsamplestep: 0.01
        lasamplerange: 0.005
        lasamplestep: 0.005

        </rosparam>
        <remap from="scan" to="scan"/>
</node>
</launch>